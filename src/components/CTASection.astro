---
export interface Props {
  title: string;
  description: string;
  ctaText: string;
  ctaHref: string;
  variant?: "light" | "dark";
}
const { title, description, ctaText, ctaHref, variant = "light" } = Astro.props;
---

<section class:list={["py-section", variant === "dark" ? "bg-surface-tile-1" : "bg-canvas"]}>
  <div class="mx-auto max-w-content px-6 md:px-10 text-center">
    <h2 class:list={["text-display-lg mb-4", variant === "dark" ? "text-body-on-dark" : "text-ink"]}>
      {title}
    </h2>
    <p class:list={["text-lg max-w-lg mx-auto mb-8", variant === "dark" ? "text-body-muted" : "text-ink-muted-80"]}>
      {description}
    </p>
    <a href={ctaHref} class="btn-primary text-base">
      {ctaText}
    </a>
  </div>
</section>

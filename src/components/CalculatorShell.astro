---
export interface Props {
  title: string;
  description: string;
  icon?: "calculator" | "slab" | "footing" | "column" | "wall" | "stairs" | "cement" | "material" | "mix" | "converter";
}
---

<div class="mx-auto w-full max-w-content px-6 md:px-10 py-section">
  <div class="mb-10">
    <h1 class="text-display-lg text-ink mb-3">{title}</h1>
    <p class="text-lg text-ink-muted-80 leading-relaxed max-w-2xl">{description}</p>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
    <div class="lg:col-span-3">
      <div class="card-container">
        <slot name="calculator" />
      </div>
    </div>
    <div class="lg:col-span-2">
      <slot name="sidebar" />
    </div>
  </div>
</div>

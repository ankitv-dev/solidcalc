---
import { breadcrumbSchema } from "../lib/seo/structured-data";

export interface Props {
  items: { name: string; url: string }[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mx-auto w-full max-w-content px-6 md:px-10 pt-6">
  <ol class="flex items-center gap-2 text-caption text-ink-muted-80 list-none p-0">
    {items.map((item, i) => (
      <li class="flex items-center gap-2">
        {i > 0 && (
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-ink-muted-80">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        )}
        {i === items.length - 1 ? (
          <span class="text-ink-muted-80">{item.name}</span>
        ) : (
          <a href={item.url} class="text-primary no-underline hover:underline">{item.name}</a>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(items))} />

---
const footerLinks = [
  {
    heading: "Calculators",
    links: [
      { href: "/concrete-calculator", label: "Concrete Calculator" },
      { href: "/slab-calculator", label: "Slab Calculator" },
      { href: "/footing-calculator", label: "Footing Calculator" },
      { href: "/column-calculator", label: "Column Calculator" },
      { href: "/wall-calculator", label: "Wall Calculator" },
      { href: "/stairs-calculator", label: "Stairs Calculator" },
    ],
  },
  {
    heading: "Materials",
    links: [
      { href: "/cement-calculator", label: "Cement Calculator" },
      { href: "/material-calculator", label: "Material Calculator" },
      { href: "/mix-design-calculator", label: "Mix Design Calculator" },
      { href: "/unit-converter", label: "Unit Converter" },
    ],
  },
  {
    heading: "Guides",
    links: [
      { href: "/guides/concrete-mix-ratios", label: "Concrete Mix Ratios" },
      { href: "/guides/cement-grades", label: "Cement Grades" },
      { href: "/guides/concrete-curing", label: "Concrete Curing" },
      { href: "/guides/concrete-strength", label: "Concrete Strength" },
      { href: "/guides/construction-materials", label: "Construction Materials" },
    ],
  },
  {
    heading: "Company",
    links: [
      { href: "/about", label: "About Us" },
      { href: "/contact", label: "Contact Us" },
      { href: "/privacy", label: "Privacy Policy" },
      { href: "/terms", label: "Terms & Conditions" },
    ],
  },
];
---

<footer class="bg-canvas-parchment py-16">
  <div class="mx-auto max-w-wide px-6 md:px-10">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 mb-12">
      <div class="col-span-2 md:col-span-3 lg:col-span-1">
      <a href="/" class="flex items-center gap-2 text-ink no-underline mb-3">
        <img src="/favicon.svg" alt="SolidCalc" class="h-5 w-auto" />
        <span class="font-body text-xs font-semibold tracking-[-0.12px]">SolidCalc</span>
      </a>
        <p class="text-fine text-ink-muted-80 max-w-xs">
          Professional concrete and construction material calculators for contractors, builders, engineers, and homeowners.
        </p>
      </div>
      {
        footerLinks.map((group) => (
          <div>
            <h4 class="font-body text-caption-strong text-ink-muted-80 mb-3">{group.heading}</h4>
            <ul class="list-none p-0 m-0">
              {
                group.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="font-body text-base font-normal leading-[2.41] text-ink-muted-80 no-underline transition-colors hover:text-primary"
                    >
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        ))
      }
    </div>
    <div class="border-t border-divider-soft pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-fine text-ink-muted-80">
        &copy; {new Date().getFullYear()} SolidCalc. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <a href="/privacy" class="text-fine text-ink-muted-80 no-underline hover:text-primary transition-colors">Privacy</a>
        <a href="/terms" class="text-fine text-ink-muted-80 no-underline hover:text-primary transition-colors">Terms</a>
        <a href="/about" class="text-fine text-ink-muted-80 no-underline hover:text-primary transition-colors">About</a>
        <a href="/contact" class="text-fine text-ink-muted-80 no-underline hover:text-primary transition-colors">Contact</a>
      </div>
    </div>
  </div>
</footer>

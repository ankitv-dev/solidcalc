---
export interface Props {
  href: string;
  label: string;
  description: string;
  icon: string;
}
const { href, label, description } = Astro.props;
---

<a
  href={href}
  class="card-container group flex flex-col gap-3 no-underline transition-all hover:shadow-elevated hover:-translate-y-0.5"
>
  <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
      <rect x="4" y="2" width="16" height="20" rx="2" />
      <line x1="8" y1="6" x2="16" y2="6" />
      <line x1="8" y1="10" x2="16" y2="10" />
      <line x1="8" y1="14" x2="12" y2="14" />
    </svg>
  </div>
  <div>
    <h3 class="font-display text-base font-semibold text-ink mb-1 group-hover:text-primary transition-colors">
      {label}
    </h3>
    <p class="text-caption text-ink-muted-80 leading-relaxed">
      {description}
    </p>
  </div>
</a>

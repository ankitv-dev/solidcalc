---
export interface Props {
  label: string;
  value: string;
  unit?: string;
  highlight?: boolean;
}
const { label, value, unit, highlight } = Astro.props;
---

<div class:list={["flex items-center justify-between py-3 px-4 rounded-lg", highlight ? "bg-primary/5" : ""]}>
  <span class="text-caption text-ink-muted-80">{label}</span>
  <span class="font-display text-lg font-semibold text-ink">
    {value}
    {unit && <span class="text-sm font-normal text-ink-muted-80 ml-1">{unit}</span>}
  </span>
</div>

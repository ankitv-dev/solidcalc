---
export interface Props {
  items: { question: string; answer: string }[];
}

const { items } = Astro.props;
---

<div class="mx-auto w-full max-w-content px-6 md:px-10 py-section">
  <h2 class="text-display-md text-ink mb-8 text-center">Frequently Asked Questions</h2>
  <div class="max-w-2xl mx-auto space-y-4">
    {
      items.map((item, i) => (
        <details class="card-container group open:border-primary/30 transition-colors">
          <summary class="cursor-pointer text-body-strong text-ink list-none flex items-center justify-between gap-4">
            {item.question}
            <svg
              class="w-5 h-5 text-ink-muted-80 shrink-0 transition-transform group-open:rotate-180"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            >
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </summary>
          <p class="mt-3 text-body text-ink-muted-80 leading-relaxed">{item.answer}</p>
        </details>
      ))
    }
  </div>
</div>

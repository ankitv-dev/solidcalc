---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
---

<BaseLayout
  title="Privacy Policy"
  description="SolidCalc privacy policy. Learn how we collect, use, and protect your personal information when using our concrete calculators and construction tools."
  canonical="https://solidcalc.vercel.app/privacy"
>
  <Breadcrumbs items={[
    { name: "Home", url: "/" },
    { name: "Privacy Policy", url: "/privacy" },
  ]} />

  <div class="mx-auto w-full max-w-content px-6 md:px-10 py-section">
    <h1 class="text-display-lg text-ink mb-3">Privacy Policy</h1>
    <p class="text-lg text-ink-muted-80 mb-10">Last updated: June 2026</p>

    <div class="max-w-3xl space-y-8">
      <section>
        <h2 class="text-display-md text-ink mb-3">Information We Collect</h2>
        <p class="text-body text-ink-muted-80 leading-relaxed">
          SolidCalc does not require an account or personal information to use our calculators. We do not collect, store, or process any personal data through our calculation tools. All calculations are performed locally in your browser.
        </p>
      </section>

      <section>
        <h2 class="text-display-md text-ink mb-3">Analytics</h2>
        <p class="text-body text-ink-muted-80 leading-relaxed">
          We may use basic analytics to understand how our website is used and improve the user experience. This includes anonymized data about page views, time on site, and browser type. No personally identifiable information is tracked.
        </p>
      </section>

      <section>
        <h2 class="text-display-md text-ink mb-3">Cookies</h2>
        <p class="text-body text-ink-muted-80 leading-relaxed">
          SolidCalc uses minimal cookies for essential functionality only. We do not use tracking cookies, advertising cookies, or third-party marketing cookies. Your region preference may be stored locally in your browser.
        </p>
      </section>

      <section>
        <h2 class="text-display-md text-ink mb-3">Third-Party Services</h2>
        <p class="text-body text-ink-muted-80 leading-relaxed">
          We do not sell, trade, or share your personal information with third parties. Our website may be hosted on Vercel, which has its own privacy policy regarding server logs and infrastructure data.
        </p>
      </section>

      <section>
        <h2 class="text-display-md text-ink mb-3">Data Security</h2>
        <p class="text-body text-ink-muted-80 leading-relaxed">
          We implement industry-standard security measures to protect any data transmitted through our website. All connections use HTTPS encryption.
        </p>
      </section>

      <section>
        <h2 class="text-display-md text-ink mb-3">Contact</h2>
        <p class="text-body text-ink-muted-80 leading-relaxed">
          If you have questions about this privacy policy, please contact us through our Contact page.
        </p>
      </section>
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import CalculatorBase from "../components/CalculatorBase.astro";
import SEOContent from "../components/SEOContent.astro";
import FAQSection from "../components/FAQSection.astro";
import { softwareAppSchema, faqSchema } from "../lib/seo/structured-data";
---

<BaseLayout
  title="Post Hole Calculator - Concrete for Fence Posts & Poles"
  description="Free post hole concrete calculator. Calculate concrete needed for fence posts, mailbox posts, and round holes. Estimate bags, volume, and cost."
  canonical="https://solidcalc.vercel.app/post-hole-calculator"
  structuredData={[
    softwareAppSchema(
      "Post Hole Calculator",
      "Free post hole concrete calculator for fence posts and poles. Calculate concrete volume, bags, and materials needed for setting posts.",
      "https://solidcalc.vercel.app/post-hole-calculator"
    ),
    faqSchema([
      { question: "How do I calculate concrete for a post hole?", answer: "Calculate the hole volume (π × radius² × depth), subtract the post volume (width² × depth for square posts, π × radius² for round), then multiply by the number of posts." },
      { question: "How deep should a fence post be?", answer: "A general rule is 1/3 of the post height should be below ground. For a 6 ft post, dig at least 24 inches deep. Always check local building codes." },
    ]),
  ]}
>
  <Breadcrumbs items={[
    { name: "Home", url: "/" },
    { name: "Post Hole Calculator", url: "/post-hole-calculator" },
  ]} />

  <div class="mx-auto w-full max-w-content px-6 md:px-10 py-section">
    <div class="mb-10">
      <h1 class="text-display-lg text-ink mb-3">Post Hole Calculator</h1>
      <p class="text-lg text-ink-muted-80 max-w-2xl">Calculate the exact amount of concrete needed for fence posts, mailbox posts, and poles. Avoid coming up short on concrete — get accurate bag counts and volume estimates.</p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
      <div class="lg:col-span-3">
        <div class="card-container">
          <div class="mb-6">
            <h3 class="text-caption-strong text-ink-muted-80 uppercase tracking-wide mb-3">Post Shape</h3>
            <div class="flex flex-wrap gap-2">
              {["square", "round"].map((t) => (
                <label class="flex items-center gap-2 px-4 py-2 rounded-pill border border-hairline text-caption text-ink-muted-80 cursor-pointer transition-all has-[:checked]:bg-primary has-[:checked]:text-white has-[:checked]:border-primary">
                  <input type="radio" name="post-shape" value={t} checked={t === "square"} class="sr-only" />
                  {t.charAt(0).toUpperCase() + t.slice(1)}
                </label>
              ))}
            </div>
          </div>

          <CalculatorBase
            calculatorId="post-hole"
            inputs={[
              {
                id: "dimensions",
                label: "Post Hole Dimensions",
                fields: [
                  { id: "holeDiameter", label: "Hole Diameter", placeholder: "e.g. 12", defaultValue: "12" },
                  { id: "holeDepth", label: "Hole Depth", placeholder: "e.g. 24", defaultValue: "24" },
                  { id: "postSize", label: "Post Width / Diameter", placeholder: "e.g. 4", defaultValue: "4" },
                  { id: "count", label: "Number of Posts", placeholder: "e.g. 10", defaultValue: "10" },
                ],
              },
              {
                id: "pricing",
                label: "Cost Estimate (Optional)",
                fields: [
                  { id: "pricePerBag", label: "Price per 50 kg Bag ($)", placeholder: "e.g. 8", defaultValue: "", step: "0.01" },
                ],
              },
            ]}
            outputs={[
              {
                id: "volume-results",
                label: "Concrete Required",
                fields: [
                  { id: "perHole", label: "Concrete per Hole", highlight: true },
                  { id: "volumeM3", label: "Total Volume", unit: "m³" },
                  { id: "volumeYd3", label: "Total Volume (yd³)", unit: "yd³" },
                  { id: "cementBags", label: "Cement Bags Required", highlight: true },
                ],
              },
              {
                id: "material-results",
                label: "Material Quantities (1:1.5:3 Mix)",
                fields: [
                  { id: "cementKg", label: "Cement", unit: "kg" },
                  { id: "sandKg", label: "Sand", unit: "kg" },
                  { id: "aggregateKg", label: "Aggregate", unit: "kg" },
                ],
              },
              {
                id: "cost-results",
                label: "Cost Estimate",
                fields: [
                  { id: "costPerBag", label: "Cost (by bag)", highlight: true },
                ],
              },
            ]}
          />
          <button type="button" class="btn-utility w-full justify-center mt-6" onclick="window.print()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            Print / Export PDF
          </button>
        </div>
      </div>
      <div class="lg:col-span-2">
        <div class="card-container space-y-4">
          <h3 class="text-caption-strong text-ink-muted-80 uppercase tracking-wide">Unit Selection</h3>
          <div class="flex flex-wrap gap-2">
            {["in", "ft", "cm", "mm"].map((u) => (
              <label class="flex items-center gap-2 px-3 py-2 rounded-pill border border-hairline text-caption text-ink-muted-80 cursor-pointer transition-all has-[:checked]:bg-primary has-[:checked]:text-white has-[:checked]:border-primary">
                <input type="radio" name="unit" value={u} checked={u === "in"} class="sr-only" />
                {u}
              </label>
            ))}
          </div>
          <div class="border-t border-divider-soft pt-4">
            <h4 class="text-caption-strong text-ink-muted-80 mb-2">Tips for Post Setting</h4>
            <ul class="text-caption text-ink-muted-80 space-y-2 list-disc list-inside">
              <li>Dig hole 3x the post width for proper concrete encasement</li>
              <li>Depth should be ~1/3 of post height above ground</li>
              <li>Add gravel at bottom for drainage</li>
              <li>Always add 10% wastage for spillage</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <SEOContent
    formula="Concrete per hole = Hole Volume - Post Volume | Hole = π × r² × depth | Post = width² × depth (square) or π × r² × depth (round)"
    steps={[
      "Measure the hole diameter and depth for your fence posts.",
      "Measure your post's width (square post) or diameter (round post).",
      "Enter the number of posts you need to set.",
      "The calculator subtracts the post volume from the hole volume to find concrete needed.",
      "Add wastage allowance for spillage and errors.",
      "Results show concrete per hole, total volume, and bags required.",
    ]}
    example={`Example: Setting 10 Fence Posts\n\nHole Diameter: 12 inches, Depth: 24 inches\nPost Width: 4 inches (square)\n\nHole Volume: π × 6² × 24 = 2,714 in³\nPost Volume: 4 × 4 × 24 = 384 in³\nConcrete per hole: 2,714 - 384 = 2,330 in³\n\nTotal: 10 × 2,330 = 23,300 in³ = 0.38 m³\n\nWith 10% wastage: 0.42 m³\n\n50 kg bags needed: ~11 bags`}
    commonMistakes={[
      "Not accounting for the post volume — the hole volume alone overestimates concrete needed.",
      "Digging holes too small — hole should be at least 3x the post width.",
      "Setting posts too shallow — at least 1/3 of post height should be underground.",
    ]}
    relatedCalculators={[
      { href: "/concrete-calculator", label: "Concrete Calculator" },
      { href: "/column-calculator", label: "Column Calculator" },
      { href: "/footing-calculator", label: "Footing Calculator" },
      { href: "/slab-calculator", label: "Slab Calculator" },
      { href: "/mix-design-calculator", label: "Mix Design Calculator" },
    ]}
  />

  <FAQSection items={[
    { question: "How much concrete do I need per fence post?", answer: "A typical 4×4 post with a 12-inch hole 24 inches deep needs about 0.04 m³ (1.4 ft³) of concrete. This requires approximately 1-2 bags of 50 kg concrete mix per post." },
    { question: "What size hole do I need for a fence post?", answer: "A good rule is to dig the hole 3 times the width of the post. For a 4×4 post, dig a 12-inch diameter hole. The depth should be at least 1/3 of the post height." },
    { question: "Should I use fast-setting concrete for posts?", answer: "Fast-setting concrete is convenient for fence posts as it sets in 20-40 minutes and doesn't require mixing in a wheelbarrow. However, standard concrete mix is stronger and more economical for large projects." },
    { question: "How long does post concrete take to cure?", answer: "Post concrete reaches initial set in 2-4 hours with standard mix (20-40 minutes with fast-set). Full cure takes 28 days. Wait at least 24 hours before applying lateral pressure to posts." },
  ]} />
<script>
  import "../lib/client-calculator";
</script>

</BaseLayout>

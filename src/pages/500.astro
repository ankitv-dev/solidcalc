---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Server Error"
  description="Something went wrong on our end. Please try again later."
>
  <div class="min-h-[70vh] flex items-center justify-center bg-canvas pt-11">
    <div class="mx-auto max-w-content px-6 md:px-10 text-center py-20">
      <div class="inline-flex items-center gap-2 bg-primary/10 text-primary text-caption font-medium px-4 py-2 rounded-pill mb-6">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        500 Error
      </div>
      <h1 class="text-hero text-ink mb-5">Something Went Wrong</h1>
      <p class="text-lead text-ink-muted-80 max-w-xl mx-auto mb-10">
        An unexpected error occurred. Please try again or contact support if the issue persists.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/" class="btn-primary text-lg px-8 py-4">Go Home</a>
        <a href="/contact" class="btn-secondary text-lg px-8 py-4">Contact Us</a>
      </div>
    </div>
  </div>
</BaseLayout>

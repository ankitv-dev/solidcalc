---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import CalculatorBase from "../components/CalculatorBase.astro";
import SEOContent from "../components/SEOContent.astro";
import FAQSection from "../components/FAQSection.astro";
import { softwareAppSchema, faqSchema } from "../lib/seo/structured-data";
import { META_DESCRIPTIONS } from "../lib/seo/keywords";
---

<BaseLayout
  title="Mix Design Calculator - Concrete Mix Proportions"
  description={META_DESCRIPTIONS.mixDesign}
  canonical="https://solidcalc.vercel.app/mix-design-calculator"
  structuredData={[
    softwareAppSchema("Mix Design Calculator", META_DESCRIPTIONS.mixDesign, "https://solidcalc.vercel.app/mix-design-calculator"),
    faqSchema([
      { question: "What is concrete mix design?", answer: "Mix design determines the optimal proportions of cement, sand, aggregate, and water to achieve the required concrete strength and workability." },
      { question: "What is the difference between M20 and M25 concrete?", answer: "M20 has a compressive strength of 20 MPa and uses a 1:1.5:3 ratio. M25 has 25 MPa strength using a 1:1:2 ratio. M25 is stronger but uses more cement." },
    ]),
  ]}
>
  <Breadcrumbs items={[
    { name: "Home", url: "/" },
    { name: "Mix Design Calculator", url: "/mix-design-calculator" },
  ]} />

  <div class="mx-auto w-full max-w-content px-6 md:px-10 py-section">
    <div class="mb-10">
      <h1 class="text-display-lg text-ink mb-3">Mix Design Calculator</h1>
      <p class="text-lg text-ink-muted-80 max-w-2xl">Design concrete mix proportions for any strength grade. Supports M10 through M30 and custom ratios with automatic water-cement ratio selection.</p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
      <div class="lg:col-span-3">
        <div class="card-container">
          <div class="mb-6">
            <h3 class="text-caption-strong text-ink-muted-80 uppercase tracking-wide mb-3">Concrete Grade</h3>
            <div class="flex flex-wrap gap-2">
              {["M10", "M15", "M20", "M25", "M30", "custom"].map((g) => (
                <label class="flex items-center gap-2 px-4 py-2 rounded-pill border border-hairline text-caption text-ink-muted-80 cursor-pointer transition-all has-[:checked]:bg-primary has-[:checked]:text-white has-[:checked]:border-primary">
                  <input type="radio" name="mix-grade" value={g} checked={g === "M20"} class="sr-only" />
                  {g}
                </label>
              ))}
            </div>
          </div>

          <CalculatorBase
            calculatorId="mix-design-calc"
            wastageOptions={false}
            inputs={[
              {
                id: "volume-input",
                label: "Concrete Volume",
                fields: [
                  { id: "volumeM3", label: "Concrete Volume (m³)", placeholder: "e.g. 5", defaultValue: "5", step: "0.1" },
                ],
              },
            ]}
            outputs={[
              {
                id: "mix-results",
                label: "Mix Proportions",
                fields: [
                  { id: "mixRatio", label: "Mix Ratio", highlight: true },
                  { id: "cementKg", label: "Cement", unit: "kg" },
                  { id: "sandKg", label: "Sand", unit: "kg" },
                  { id: "aggregateKg", label: "Aggregate", unit: "kg" },
                  { id: "waterLiters", label: "Water", unit: "L" },
                  { id: "cementBags", label: "Cement Bags (50 kg)", highlight: true },
                ],
              },
            ]}
          />
        </div>
      </div>
      <div class="lg:col-span-2">
        <div class="card-container space-y-4">
          <h3 class="text-caption-strong text-ink-muted-80 uppercase tracking-wide">Grade Specifications</h3>
          <div class="space-y-2 text-caption text-ink-muted-80">
            <p><strong class="text-ink">M10</strong> — 10 MPa | 1:3:6 | W/C: 0.60</p>
            <p><strong class="text-ink">M15</strong> — 15 MPa | 1:2:4 | W/C: 0.55</p>
            <p><strong class="text-ink">M20</strong> — 20 MPa | 1:1.5:3 | W/C: 0.50</p>
            <p><strong class="text-ink">M25</strong> — 25 MPa | 1:1:2 | W/C: 0.45</p>
            <p><strong class="text-ink">M30</strong> — 30 MPa | 1:0.75:1.5 | W/C: 0.40</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <SEOContent
    formula="Cement = (C ÷ (C+S+A)) × Dry Vol × 1440 | w/c ratio determines water content"
    steps={[
      "Select the required concrete grade (M10 to M30) or choose custom ratios.",
      "Enter the total concrete volume needed for your project.",
      "The calculator automatically applies the standard mix ratio and water-cement ratio for the selected grade.",
      "For custom mixes, you can specify your own cement:sand:aggregate ratio and water-cement ratio.",
      "Results show precise material quantities for ordering.",
    ]}
    example={`Example: 5 m³ of M25 Concrete\n\nMix Ratio: 1:1:2 (Cement:Sand:Aggregate)\nW/C Ratio: 0.45\n\nDry Volume = 5 × 1.54 = 7.7 m³\nCement = (1/4) × 7.7 × 1440 = 2,772 kg\nSand = (1/4) × 7.7 × 1600 = 3,080 kg\nAggregate = (2/4) × 7.7 × 1500 = 5,775 kg\nWater = 2,772 × 0.45 = 1,247 L\n\nCement bags: 56 bags (50 kg)`}
    relatedCalculators={[
      { href: "/concrete-calculator", label: "Concrete Calculator" },
      { href: "/material-calculator", label: "Material Calculator" },
      { href: "/cement-calculator", label: "Cement Calculator" },
    ]}
  />

  <FAQSection items={[
    { question: "What is the water-cement ratio and why does it matter?", answer: "The water-cement ratio is the weight of water divided by the weight of cement. A lower w/c ratio increases strength but reduces workability. Typical range: 0.40-0.60." },
    { question: "Can I use this for high-strength concrete above M30?", answer: "For concrete above M30, specialized mix designs with admixtures and quality control are required. Consult a concrete technologist for high-strength mixes." },
    { question: "How do I adjust the mix for different aggregates?", answer: "The standard mix ratios assume normal-weight aggregates. For lightweight or heavy-weight aggregates, adjust the mix design accordingly. Use the custom ratio option." },
  ]} />
<script>
  import "../lib/client-calculator";
</script>

</BaseLayout>

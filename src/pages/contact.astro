---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { breadcrumbSchema } from "../lib/seo/structured-data";
---

<BaseLayout
  title="Contact Us - SolidCalc Support"
  description="Get in touch with SolidCalc. Contact us with questions, feedback, or suggestions about our concrete calculators and construction tools."
  canonical="https://solidcalc.vercel.app/contact"
  structuredData={[breadcrumbSchema([{name:"Home", url:"/"},{name:"Contact Us", url:"/contact"}])]}
>
  <Breadcrumbs items={[
    { name: "Home", url: "/" },
    { name: "Contact Us", url: "/contact" },
  ]} />

  <div class="mx-auto w-full max-w-content px-6 md:px-10 py-section text-center">
    <h1 class="text-display-lg text-ink mb-3">Contact Us</h1>
    <p class="text-lg text-ink-muted-80 max-w-2xl mx-auto mb-10">Reach out to us anytime.</p>

    <div class="max-w-md mx-auto space-y-4">
      <div class="card-container">
        <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <p class="text-body text-ink break-all">ankit.kumar.verma.dev@gmail.com</p>
      </div>
      <a href="https://github.com/ankitkumarverma" target="_blank" rel="noopener noreferrer" class="btn-secondary inline-flex items-center gap-2">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        GitHub
      </a>
    </div>
  </div>
</BaseLayout>

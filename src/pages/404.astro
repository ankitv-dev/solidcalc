---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Browse our free concrete calculators instead."
>
  <div class="min-h-[70vh] flex items-center justify-center bg-canvas pt-11">
    <div class="mx-auto max-w-content px-6 md:px-10 text-center py-20">
      <div class="inline-flex items-center gap-2 bg-primary/10 text-primary text-caption font-medium px-4 py-2 rounded-pill mb-6">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="15" y1="9" x2="9" y2="15"/>
          <line x1="9" y1="9" x2="15" y2="15"/>
        </svg>
        404 Error
      </div>
      <h1 class="text-hero text-ink mb-5">Page Not Found</h1>
      <p class="text-lead text-ink-muted-80 max-w-xl mx-auto mb-10">
        The page you were looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/" class="btn-primary text-lg px-8 py-4">Go Home</a>
        <a href="/concrete-calculator" class="btn-secondary text-lg px-8 py-4">Try a Calculator</a>
      </div>
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import CalculatorBase from "../components/CalculatorBase.astro";
import SEOContent from "../components/SEOContent.astro";
import FAQSection from "../components/FAQSection.astro";
import { softwareAppSchema, faqSchema } from "../lib/seo/structured-data";
import { META_DESCRIPTIONS } from "../lib/seo/keywords";
---

<BaseLayout
  title="Cement Calculator - Estimate Cement Bags for Concrete"
  description={META_DESCRIPTIONS.cement}
  canonical="https://solidcalc.vercel.app/cement-calculator"
  structuredData={[
    softwareAppSchema("Cement Calculator", META_DESCRIPTIONS.cement, "https://solidcalc.vercel.app/cement-calculator"),
    faqSchema([
      { question: "How many cement bags do I need?", answer: "Divide the total cement weight by the bag size. For M20 mix (1:1.5:3), one cubic meter of concrete needs approximately 8 bags of 50 kg cement." },
      { question: "What is the cement consumption per m³ of concrete?", answer: "For M20 mix: ~400 kg/m³ (8 bags). For M15: ~320 kg/m³ (6.5 bags). For M25: ~480 kg/m³ (9.6 bags)." },
    ]),
  ]}
>
  <Breadcrumbs items={[
    { name: "Home", url: "/" },
    { name: "Cement Calculator", url: "/cement-calculator" },
  ]} />

  <div class="mx-auto w-full max-w-content px-6 md:px-10 py-section">
    <div class="mb-10">
      <h1 class="text-display-lg text-ink mb-3">Cement Calculator</h1>
      <p class="text-lg text-ink-muted-80 max-w-2xl">Calculate the number of cement bags required for your concrete project based on volume and standard mix ratios.</p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
      <div class="lg:col-span-3">
        <div class="card-container">
          <CalculatorBase
            calculatorId="cement-calc"
            wastageOptions={false}
            inputs={[
              {
                id: "volume-input",
                label: "Concrete Volume",
                fields: [
                  { id: "volumeM3", label: "Concrete Volume (m³)", placeholder: "e.g. 5", defaultValue: "5", step: "0.1" },
                ],
              },
            ]}
            outputs={[
              {
                id: "cement-results",
                label: "Cement Requirements",
                fields: [
                  { id: "cementKg", label: "Cement Required", unit: "kg", highlight: true },
                  { id: "cementBags", label: "Cement Bags (50 kg)", highlight: true },
                  { id: "sandKg", label: "Sand", unit: "kg" },
                  { id: "aggregateKg", label: "Aggregate", unit: "kg" },
                ],
              },
            ]}
          />
        </div>
      </div>
      <div class="lg:col-span-2">
        <div class="card-container space-y-4">
          <h3 class="text-caption-strong text-ink-muted-80 uppercase tracking-wide">Standard Mix: 1:1.5:3 (M20)</h3>
          <p class="text-caption text-ink-muted-80">This calculator uses the M20 mix ratio (1:1.5:3) standard for general construction. For different mixes, use the Mix Design Calculator.</p>
          <div class="border-t border-divider-soft pt-4">
            <h4 class="text-caption-strong text-ink-muted-80 mb-2">Quick Reference</h4>
            <div class="text-caption text-ink-muted-80 space-y-1">
              <p>M10: 1:3:6 → ~4.5 bags/m³</p>
              <p>M15: 1:2:4 → ~6.5 bags/m³</p>
              <p>M20: 1:1.5:3 → ~8 bags/m³</p>
              <p>M25: 1:1:2 → ~9.6 bags/m³</p>
              <p>M30: 1:0.75:1.5 → ~11 bags/m³</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <SEOContent
    formula="Cement (kg) = (Cement Ratio ÷ Total Ratio) × Dry Volume × 1440"
    steps={[
      "Determine the total concrete volume needed for your project.",
      "Select the appropriate mix ratio for your application.",
      "The calculator uses the dry volume method (wet volume × 1.54).",
      "Cement content is calculated based on the mix proportions.",
      "Divide total cement weight by bag size to get the number of bags.",
    ]}
    example={`Example: 5 m³ Concrete (M20 Mix)\n\nDry Volume = 5 × 1.54 = 7.7 m³\nCement = (1/5.5) × 7.7 × 1440 = 2,016 kg\n\n50 kg bags needed: 2,016 ÷ 50 = 40.3 → 41 bags\n\nAlso needed:\nSand: 3,024 kg\nAggregate: 6,048 kg`}
    relatedCalculators={[
      { href: "/concrete-calculator", label: "Concrete Calculator" },
      { href: "/material-calculator", label: "Material Calculator" },
      { href: "/mix-design-calculator", label: "Mix Design Calculator" },
    ]}
  />

  <FAQSection items={[
    { question: "How much cement is in a standard bag?", answer: "Standard cement bags are 50 kg (110 lbs) in most countries. In the US, 60 lb and 94 lb bags are also common. Check your local availability." },
    { question: "Can I use the calculator for mortar?", answer: "This calculator is designed for concrete. Mortar has different mix proportions (typically 1:3 to 1:6 cement to sand ratio)." },
    { question: "How long does cement last in storage?", answer: "Cement should be used within 3 months of purchase if stored properly in dry conditions. Moisture exposure reduces cement strength significantly." },
  ]} />
<script>
  import "../lib/client-calculator";
</script>

</BaseLayout>

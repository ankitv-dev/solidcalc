---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  robots?: string;
  structuredData?: Record<string, unknown>[];
}

const { title, description, canonical, ogImage, robots, structuredData } = Astro.props;
const robotsContent = robots || "index, follow";
const canonicalUrl = canonical || `https://solidcalc.vercel.app${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en" class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | SolidCalc</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | SolidCalc`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="SolidCalc" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | SolidCalc`} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#0066cc" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MBWN6F9ZXQ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-MBWN6F9ZXQ');
    </script>

    <!-- Google AdSense (primed for future activation) -->
    <script is:inline>
      (function() {
        // Uncomment the line below and replace with your publisher ID to enable AdSense
        // (window.adsbygoogle = window.adsbygoogle || []).push({});
      })();
    </script>
    <!-- <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script> -->

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    {structuredData?.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}

    <script is:inline>
      const theme = localStorage.getItem('theme') || 'light';
      document.documentElement.className = theme;
    </script>
  </head>
  <body class="min-h-screen bg-canvas text-body antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
